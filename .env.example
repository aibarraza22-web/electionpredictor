# Copy to .env and fill in. Never commit production credentials.

# Managed PostgreSQL (Neon, Vercel Postgres, RDS, ...). Unset = local SQLite.
DATABASE_URL=postgresql://user:password@host:5432/forecast

# Required to enable the /api/admin/* endpoints (disabled when unset).
ADMIN_TOKEN=

# Optional: campaign finance ingestion (free key: https://api.data.gov/signup/)
FEC_API_KEY=

# Optional: live 2026 polling feed, any CSV in the 538 raw-polls schema.
POLLS_FEED_URL=
