# Copy to .env and fill in. Never commit production credentials.

# Managed PostgreSQL (Neon, Vercel Postgres, RDS, ...). Unset = local SQLite.
DATEBASE_URL=postgresql://user:password@host:5432/forecast

# Required to enable the /api/admin/* endpoints (disabled when unset).
ADMIN_TOKEN=

# Optional: campaign finance ingestion (free key: https://api.data.gov/signup/)
FEC_API_KEY=

# Optional but high-value: unlocks the full MEDSL House district-results file
# (raises most House races from data grade D to C). Requires a free Harvard
# Dataverse account that has satisfied that dataset's guestbook once, then an
# API token from account settings. See app/ingest/medsl.py for exact steps.
DATAVERSE_API_KEY=

# Optional: live 2026 polling feed, any CSV in the 538 raw-polls schema.
POLLS_FEED_URL=
